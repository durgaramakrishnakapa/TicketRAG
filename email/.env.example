# Copy to .env and fill in. Do not commit .env.
GEMINI_API_KEY=your-gemini-api-key
QUERY_API_BASE_URL=http://localhost:8000

# Optional: Gmail API (OAuth2). Place client_secret_*.json in project root, or set path:
# GMAIL_CREDENTIALS_JSON=client_secret_xxx.apps.googleusercontent.com.json

# Optional: SMTP (if not using Gmail API)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=agent@example.com
